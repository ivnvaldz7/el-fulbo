{
  "name": "el-fulbo",
  "version": "0.1.0",
  "private": true,
  "description": "PWA para organizar fulbito amateur con evento, confirmacion, sorteo, resultado y memoria.",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rimraf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --dir src",
    "test:unit": "vitest run --dir src",
    "test:integration": "npm run supabase db reset && vitest run --dir tests/integration",
    "test:e2e": "playwright test",
    "test:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "supabase": "supabase"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/react-query": "^5.100.5",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "lucide-react": "^1.11.0",
    "next": "^14.2.35",
    "next-pwa": "^5.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jszip": "^3.4.1",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^29.0.2",
    "msw": "^2.14.6",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "supabase": "^2.106.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
